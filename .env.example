# Flask runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
FLASK_SECRET_KEY=change-me

# Frontend dist path in container
FRONTEND_DIST_DIR=/app/frontend/dist

# SQLite runtime
DATA_DIR=/app/data
SQLITE_PATH=/app/data/smart-box.db
SEED_PATH=/app/seed_data.json

# Logging
LOG_DIR=/app/logs
LOG_FILE=smart-box.log
LOG_LEVEL=INFO
LOG_BACKUP_DAYS=14

# RFID reader on Raspberry Pi RC522
RFID_READER_MODE=rc522
START_RFID_READER=true
RFID_DEBOUNCE_SECONDS=1.5
RC522_SPI_BUS=0
RC522_SPI_DEVICE=0
RC522_RST_GPIO=25
RC522_GPIO_MODE=BCM

# Station control via Raspberry Pi GPIO
STATION_SIGNAL_MODE=gpio
ENABLE_STATION_SIGNAL=true
STATION_SIGNAL_GPIO=24
STATION_SIGNAL_ACTIVE_LEVEL=low

# Optional serial controller, only if you still keep an external board
ENABLE_SERIAL_CONTROLLER=false
SERIAL_DEVICE_MAPPING=/dev/null:/dev/null
SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUDRATE=9600
SERIAL_TIMEOUT=0.5

# Docker access to Raspberry Pi hardware
DOCKER_PRIVILEGED=true
GPIO_GROUP_ID=997

# Admin access
ADMIN_SESSION_TIMEOUT_SECONDS=1800
ENABLE_LOCAL_DEBUG_SDK=true

# Kiosk mode
ENABLE_WEBVIEW=false
