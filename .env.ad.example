# Active Directory sync settings.
# Copy this file to .env.ad and adjust values on the target machine.
AD_SERVER=192.168.100.1
AD_USER=hta\sync
AD_PASSWORD=change-me
AD_SEARCH_BASE=OU=Users,OU=Corporate,DC=hta,DC=local

# Optional overrides.
# DATA_DIR=/app/data
# SQLITE_PATH=/app/data/smart-box.db
# AD_EXPORT_CSV_PATH=/app/data/ad_users_export.csv
